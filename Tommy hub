-- Ryzen Ultimate Script v2.0
local Player = game:GetService("Players").LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local Root = Character:WaitForChild("HumanoidRootPart")
local Camera = workspace.CurrentCamera

-- Настройки
local Speed = 50
local JumpPower = 100
local ESP_Color = Color3.fromRGB(255, 0, 0)

-- Fly
local Fly = false
local BodyGyro = Instance.new("BodyGyro")
local BodyVelocity = Instance.new("BodyVelocity")
BodyGyro.P = 9e4
BodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
BodyGyro.CFrame = Root.CFrame
BodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
BodyVelocity.Velocity = Vector3.new(0, 0, 0)
BodyGyro.Parent = Root
BodyVelocity.Parent = Root

game:GetService("UserInputService").InputBegan:Connect(function(Key)
    if Key.KeyCode == Enum.KeyCode.F then
        Fly = not Fly
        if Fly then
            BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end
end)

game:GetService("RunService").Heartbeat:Connect(function()
    if Fly then
        local Move = Vector3.new(0, 0, 0)
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) then Move = Move + Camera.CFrame.LookVector * Speed end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.S) then Move = Move - Camera.CFrame.LookVector * Speed end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.A) then Move = Move - Camera.CFrame.RightVector * Speed end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.D) then Move = Move + Camera.CFrame.RightVector * Speed end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) then Move = Move + Vector3.new(0, Speed, 0) end
        if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.LeftShift) then Move = Move - Vector3.new(0, Speed, 0) end
        BodyVelocity.Velocity = Move
        BodyGyro.CFrame = Camera.CFrame
    end
end)

-- Noclip
local Noclip = false
game:GetService("UserInputService").InputBegan:Connect(function(Key)
    if Key.KeyCode == Enum.KeyCode.N then
        Noclip = not Noclip
        if Noclip then
            Character:WaitForChild("Head").CanCollide = false
            for _, v in ipairs(Character:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        else
            for _, v in ipairs(Character:GetChildren()) do
                if v:IsA("BasePart") then v.CanCollide = true end
            end
        end
    end
end)

-- Wallhop (проход сквозь стены по Shift+W)
game:GetService("UserInputService").InputBegan:Connect(function(Key)
    if Key.KeyCode == Enum.KeyCode.W and game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.LeftShift) then
        Root.CFrame = Root.CFrame + Root.CFrame.LookVector * 20
    end
end)

-- ESP (Boxes + Nametags)
local ESP_Enabled = false
game:GetService("UserInputService").InputBegan:Connect(function(Key)
    if Key.KeyCode == Enum.KeyCode.E then
        ESP_Enabled = not ESP_Enabled
        if ESP_Enabled then
            for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
                if plr ~= Player then
                    local highlight = Instance.new("Highlight")
                    highlight.Adornee = plr.Character
                    highlight.FillColor = ESP_Color
                    highlight.OutlineColor = Color3.new(1,1,1)
                    highlight.Parent = plr.Character
                end
            end
        else
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("Highlight") then v:Destroy() end
            end
        end
    end
end)

-- Индикация
Player.PlayerGui:SetCore("SendNotification", {
    Title = "Ryzen Cheat",
    Text = "F = Fly | N = Noclip | E = ESP | Shift+W = Wallhop",
    Duration = 10
})
