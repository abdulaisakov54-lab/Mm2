-- Ryzen BBFT MegaScript v2.0 (Полный функционал)
local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local replicatedStorage = game:GetService("ReplicatedStorage")
local runService = game:GetService("RunService")

-- ========== 1. АВТОФАРМ (сбор ресурсов) ==========
local function autoFarm()
    local blocks = workspace:GetDescendants()
    for _, v in pairs(blocks) do
        if v:IsA("Part") and v.Name:lower():find("block") and v.Transparency == 0 then
            local dist = (v.Position - hrp.Position).Magnitude
            if dist < 30 and v.Anchored == false then
                hrp.CFrame = CFrame.new(v.Position + Vector3.new(0, 2, 0))
                wait(0.1)
                -- Симуляция сбора (клик)
                local click = v:FindFirstChild("ClickDetector")
                if click then fireclickdetector(click) end
            end
        end
    end
end

-- ========== 2. АВТОСТРОЙКА (шаблон корабля) ==========
local shipParts = {
    {size = Vector3.new(8, 1, 12), color = BrickColor.Red(), pos = Vector3.new(0, 0, 0)},
    {size = Vector3.new(8, 1, 2), color = BrickColor.Yellow(), pos = Vector3.new(0, 1, 5)},
    {size = Vector3.new(2, 1, 12), color = BrickColor.Green(), pos = Vector3.new(4, 1, 0)},
    {size = Vector3.new(2, 1, 12), color = BrickColor.Green(), pos = Vector3.new(-4, 1, 0)}
}

local function autoBuild()
    local model = Instance.new("Model")
    model.Name = "AutoShip"
    for _, data in ipairs(shipParts) do
        local part = Instance.new("Part")
        part.Size = data.size
        part.BrickColor = data.color
        part.Anchored = true
        part.CFrame = CFrame.new(hrp.Position + data.pos + Vector3.new(0, -2, 10))
        part.Parent = model
    end
    model.Parent = workspace
    return model
end

-- ========== 3. КОПИРОВАНИЕ ПОСТРОЕК ==========
local function copyBuild(targetModel)
    if not targetModel then return end
    local clone = targetModel:Clone()
    clone.Parent = workspace
    local primary = clone:GetPrimaryPartCFrame()
    if primary then
        clone:SetPrimaryPartCFrame(primary * CFrame.new(15, 0, 0))
    end
    return clone
end

-- ========== 4. GUI УПРАВЛЕНИЕ ==========
local screen = Instance.new("ScreenGui")
screen.Parent = player.PlayerGui

local function createButton(text, posY, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 180, 0, 35)
    btn.Position = UDim2.new(0, 10, 0, posY)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BorderSizePixel = 0
    btn.Parent = screen
    btn.MouseButton1Click:Connect(callback)
    return btn
end

createButton("Автофарм (вкл)", 10, function()
    runService.Heartbeat:Connect(autoFarm)
    print("Автофарм активен")
end)

createButton("Построить корабль", 50, function()
    local ship = autoBuild()
    print("Корабль построен!")
end)

createButton("Копировать постройку (цель)", 90, function()
    local target = workspace:FindFirstChild("AutoShip") or workspace:FindFirstChildOfClass("Model")
    if target then
        copyBuild(target)
        print("Копия создана")
    else
        print("Нет цели для копирования")
    end
end)

createButton("Телепорт к сокровищу", 130, function()
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Part") and v.Name:lower():find("treasure") then
            hrp.CFrame = CFrame.new(v.Position + Vector3.new(0, 3, 0))
